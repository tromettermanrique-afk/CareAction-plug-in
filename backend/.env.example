# CareAction backend config

# Local server
CAREACTION_PORT=3000

# Cloud PostgreSQL. Render + Neon will use this.
# Leave empty for local SQLite mode.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# External data source.
# none: only use local SQLite data
# api: call a third-party REST API
# sqlite: read a third-party/exported SQLite database
# postgres: read a third-party PostgreSQL/Neon database
EXTERNAL_SOURCE_TYPE=none

# REST API source example
EXTERNAL_API_BASE=https://example.com/api
EXTERNAL_API_RECORDS_URL=https://example.com/api/records?elder_id={elder_id}
EXTERNAL_API_TOKEN=replace-with-third-party-token

# External SQLite source example
EXTERNAL_SQLITE_PATH=C:\path\to\third_party.sqlite3
EXTERNAL_SQLITE_QUERY=SELECT type, source, time_label AS time, text, confidence FROM care_records WHERE elder_id = ? LIMIT 50

# External PostgreSQL/Neon read-only source example.
# Keep this different from DATABASE_URL. DATABASE_URL is CareAction's own database.
EXTERNAL_POSTGRES_URL=postgresql://readonly_user:password@host/dbname?sslmode=require
EXTERNAL_POSTGRES_QUERY=SELECT type, source, time_label AS time, text, confidence FROM care_records WHERE elder_id = %s ORDER BY time_label DESC LIMIT 50

# AI API. Use any OpenAI-compatible chat/completions provider.
# Examples: OpenAI, DeepSeek, Qwen-compatible gateways, self-hosted compatible gateways.
AI_PROVIDER=openai-compatible
AI_API_BASE=https://api.deepseek.com
AI_API_KEY=replace-with-your-ai-api-key
AI_MODEL=deepseek-v4-pro
